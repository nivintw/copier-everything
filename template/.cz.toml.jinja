# commitizen config — standalone so it's language-agnostic (lives here whether or not
# the repo is Python). Enforces Conventional Commits + gitmoji, and `cz bump` computes
# the version + CHANGELOG.md from history and cuts the annotated `v$version` tag.
#
# version_provider = where the version-of-record lives:
{%- if has_python %}
#   uv         → pyproject.toml [project].version (a wheel build reads it)
{%- else %}
#   commitizen → the `version` field right here (works on a fresh, tagless repo)
{%- endif %}

[tool.commitizen]
name = "cz_gitmoji"
version_provider = "{{ 'uv' if has_python else 'commitizen' }}"
{%- if not has_python %}
version = "0.0.0"
{%- endif %}
update_changelog_on_bump = true
annotated_tag = true
tag_format = "v$version"
bump_message = "🔖 bump: $current_version → $new_version"
