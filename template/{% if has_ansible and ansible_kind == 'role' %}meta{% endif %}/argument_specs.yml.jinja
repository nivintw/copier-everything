---
# Role argument validation (the role's meta/argument_specs.yml).
argument_specs:
  main:
    short_description: {% if project_description %}{{ project_description }}{% else %}The {{ ansible_name }} role{% endif +%}
    options:
      {{ ansible_name }}_enabled:
        type: bool
        default: true
        description: Whether the role performs its tasks.
