# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

# hawkeye (https://github.com/korandoru/hawkeye) — inserts & maintains SPDX license
# headers for REUSE compliance. Run: `hawkeye format` (or `check`). Header text is
# templated from [properties] so year/holder/license live in one place. Only files
# with no usable comment syntax stay in REUSE.toml (strict JSON, lockfiles).

# REUSE-IgnoreStart — this template literally contains an SPDX-License-Identifier line;
# without the guard, `reuse lint` tries to parse the placeholder as a license.
inlineHeader = """
SPDX-FileCopyrightText: © {{ '{{' }} props["inceptionYear"] {{ '}}' }} {{ '{{' }} props["copyrightHolder"] {{ '}}' }}
SPDX-License-Identifier: {{ '{{' }} props["spdxLicenseIdentifier"] {{ '}}' }}
"""
# REUSE-IgnoreEnd

# Negations cancel hawkeye's built-in default excludes (which skip **/*.md and
# **/.gitignore) so those get headered too.
excludes = [
  "LICENSE",
  "LICENSES/**",
  "uv.lock",
  "**/*.json",
  "!**/*.md",
  "!**/.gitignore",
  "**/.python-version",
  "**/.vscode/*",
{%- if include_helm %}
  "**/Chart.lock",
{%- endif %}
]

additionalHeaders = ["markdown-header.toml"]

[mapping.MARKDOWN_CUSTOM]
extensions = ["md"]

# '#'-comment files hawkeye doesn't map by default.
[mapping.SCRIPT_STYLE]
extensions = ["txt"{% if include_terraform %}, "tf"{% endif %}]
filenames = [".gitignore", ".envrc", ".dockerignore"{% if include_helm %}, ".helmignore"{% endif %}]

[properties]
inceptionYear = "{{ year }}"
spdxLicenseIdentifier = "{{ license }}"
copyrightHolder = "{{ author_name }}"
