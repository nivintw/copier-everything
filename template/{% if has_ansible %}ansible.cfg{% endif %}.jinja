# Ansible configuration. Galaxy content from requirements.yml installs to Ansible's default
# path (~/.ansible/collections) — where ansible-lint, Molecule, and ansible-playbook all resolve
# it without a relative path that Molecule's ephemeral runs can't follow. Local roles live in
# ./roles.
[defaults]
roles_path = ./roles
