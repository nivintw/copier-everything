{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "separate-pull-requests": true,
  "packages": {
{%- if has_python or (has_ansible and ansible_kind == 'collection') %}
    ".": {
      "extra-files": [
{%- set sep = joiner(",") %}
{%- if has_python %}
        {{ sep() }}{ "type": "toml", "path": "pyproject.toml", "jsonpath": "$.project.version" },
        { "type": "toml", "path": "uv.lock", "jsonpath": "$.package[?(@.name.value=='{{ project_slug }}')].version" }
{%- endif %}
{%- if has_ansible and ansible_kind == 'collection' %}
        {{ sep() }}{ "type": "yaml", "path": "galaxy.yml", "jsonpath": "$.version" }
{%- endif %}
      ]
    }
{%- else %}
    ".": {}
{%- endif %}
  }
}
