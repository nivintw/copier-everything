# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

version = 1

# Files that can't carry an SPDX header (no comment syntax / generated). Everything
# else gets a real header from hawkeye (see licenserc.toml).
[[annotations]]
path = [
  "**/*.json",
  "**/.python-version",
  "**/.vscode/*",
  "uv.lock",
]
SPDX-FileCopyrightText = "© {{ year }} {{ author_name }}"
SPDX-License-Identifier = "{{ license }}"
