# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

version = 1

# .gitignore stays in hawkeye's default excludes (not re-included via a negation) and is
# licensed here instead of via an inline header.
[[annotations]]
path = ".gitignore"
SPDX-FileCopyrightText = "© {{ year }} {{ author_name }}"
SPDX-License-Identifier = "{{ license }}"
{% if include_docs_site %}
# The favicon is a graphic asset, not a text file hawkeye can header inline.
[[annotations]]
path = "docs/assets/favicon.svg"
SPDX-FileCopyrightText = "© {{ year }} {{ author_name }}"
SPDX-License-Identifier = "{{ license }}"
{% endif %}

# Files that can't carry an SPDX header (no comment syntax / generated). Everything
# else gets a real header from hawkeye (see .config/licenserc.toml).
{%- if markdown_has_frontmatter %}
# Markdown is included here (not headered inline by hawkeye) because this project has
# frontmatter-first markdown where a line-1 SPDX comment would break the YAML.
{%- endif %}
[[annotations]]
path = ["**/*.json", "**/.vscode/*"{% if has_python %}, "**/.python-version", "uv.lock"{% endif %}{% if markdown_has_frontmatter %}, "**/*.md"{% endif %}]
SPDX-FileCopyrightText = "© {{ year }} {{ author_name }}"
SPDX-License-Identifier = "{{ license }}"
