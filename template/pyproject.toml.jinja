# SPDX-FileCopyrightText: © {{ year }} {{ author_name }}
# SPDX-License-Identifier: {{ license }}

{% if not include_python -%}
# This repo isn't a Python package — pyproject.toml exists to host the shared tooling
# config (commitizen, ruff) and give uv a managed dev environment. Run: uv run <tool>.
{% endif -%}
[project]
name = "{{ project_slug }}"
version = "0.0.0"
requires-python = ">=3.13"
description = "{{ project_description }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
license = "{{ license }}"
license-files = ["LICENSE", "LICENSES/*"]
classifiers = ["Programming Language :: Python :: 3"]
dependencies = []

[dependency-groups]
dev = [
  "ruff>=0.8",
  "commitizen>=3",
  "cz-conventional-gitmoji>=0.6",
{%- if include_python %}
  "pytest>=8",
  "ty>=0.0.1",
{%- endif %}
]

[tool.uv]
package = {{ 'true' if include_python else 'false' }}

{% if include_python -%}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ python_package }}"]

[tool.pytest.ini_options]
testpaths = ["tests"]

{% endif -%}
[tool.ruff]
target-version = "py313"
line-length = 100

[tool.ruff.format]
docstring-code-format = true

[tool.ruff.lint]
extend-select = ["ALL"]
ignore = ["D203", "D212", "D401", "COM812", "ISC001"]

[tool.ruff.lint.pydocstyle]
convention = "google"
{% if include_python %}
[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S101", "INP001"]  # tests use assert; not an importable package
{% endif %}
[tool.commitizen]
name = "cz_gitmoji"
version_provider = "uv"
update_changelog_on_bump = true
annotated_tag = true
tag_format = "v$version"
bump_message = "🔖 bump: $current_version → $new_version"
