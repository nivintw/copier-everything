{
  "name": "{{ project_name }}",
{%- if has_python %}
  "image": "mcr.microsoft.com/devcontainers/python:{{ python_version }}",
  "postCreateCommand": "pip install uv && uv sync{% if has_ansible %} && uvx --from ansible-core ansible-galaxy install -r requirements.yml{% endif %}",
{%- elif has_ansible %}
  // Ansible tooling is Python-based, so use a Python image even for an Ansible-only repo.
  // python_version's `when: has_python` only skips the QUESTION here — Copier still resolves
  // its default into the Jinja context, so this can reference it like the has_python branch does.
  "image": "mcr.microsoft.com/devcontainers/python:{{ python_version }}",
  "postCreateCommand": "pip install uv && uv tool install ansible-lint && uvx --from ansible-core ansible-galaxy install -r requirements.yml",
{%- else %}
  "image": "mcr.microsoft.com/devcontainers/base:debian",
{%- endif %}
  "customizations": {
    "vscode": {
{%- if has_python %}
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python"
      },
{%- endif %}
      "extensions": [
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"{% if has_ansible %},
        "redhat.ansible"{% endif %}
      ]
    }
  }
}
