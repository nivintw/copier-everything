# rumdl (markdown lint/format) config. See https://github.com/rvben/rumdl.

[global]
# Don't enforce a hard line length on prose.
disable = ["MD013"]
# CHANGELOG.md is generated by commitizen (starts at an H2 → MD041 trips).
exclude = ["LICENSE", "LICENSES/**", "CHANGELOG.md"]

[MD046]
# Always use fenced code blocks (```lang), never 4-space-indented.
style = "fenced"
